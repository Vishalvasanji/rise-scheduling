# RISE Schedule Hub — backend config (env vars only; no secrets in code)

# Data-access layer connection URL. SQLite for the pilot; swap to Turso (libSQL)
# or Postgres later by changing ONLY this URL — no code changes.
#   SQLite (local pilot):   sqlite:///./rise_schedule.db
#   Turso (libSQL) later:   sqlite+libsql://<db>.turso.io?authToken=<token>
#   Postgres (prod) later:  postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./rise_schedule.db

# Auth (pilot only — in-house, swaps to Entra ID before real data).
AUTH_MODE=jwt
AUTH_SECRET=change-me-in-real-deployments-this-is-a-pilot-dummy-secret
AUTH_TOKEN_TTL_MINUTES=43200  # 30 days

# Project schedule anchor (P1 pilot start). Others stagger ±3 months around it.
PILOT_ANCHOR_DATE=2026-06-22

# CORS origin for the Vite front end.
FRONTEND_ORIGIN=http://localhost:5173
